# Скопируйте в local.oauth.env и заполните. Файл local.oauth.env в git не попадает.
YANDEX_OAUTH_CLIENT_ID=your_client_id
YANDEX_OAUTH_CLIENT_SECRET=your_client_secret
YANDEX_OAUTH_REDIRECT_URI=https://oauth.yandex.ru/verification_code
YANDEX_METRIKA_OAUTH_TOKEN=
# Опционально: ids= в отчётах, если не указан другой счётчик
YANDEX_METRIKA_DEFAULT_COUNTER_ID=
